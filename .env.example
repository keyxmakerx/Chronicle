# ============================================================================
# Chronicle Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# --- Application ---
PORT=8080
ENV=development
BASE_URL=http://localhost:8080
LOG_LEVEL=debug

# --- Database (MariaDB) ---
# DB_HOST accepts host:port format. Port defaults to 3306 if omitted.
# DATABASE_URL overrides all individual vars if set (for full DSN control).
# DB_TLS_MODE: "disabled" (default), "required" (verify cert), "skip-verify",
#              or "preferred" (TLS if available). Set to "required" in production.
DB_HOST=localhost:3306
DB_USER=chronicle
DB_PASSWORD=chronicle
DB_NAME=chronicle
# DB_TLS_MODE=required

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Security ---
# Generate with: openssl rand -base64 32
SECRET_KEY=change-me-generate-a-real-secret-key

# --- Sessions ---
SESSION_TTL=720h

# --- File Uploads ---
MAX_UPLOAD_SIZE=10MB

# --- Backups ---
# BACKUP_DIR enables the in-process pre-migration safety net. On every boot,
# before migrations run, the server dumps the current DB to a gzip file
# under this path so an upgrade that introduces a bad migration can be
# rolled back. The default in docker-compose.yml puts backups inside the
# chronicle-data volume so they survive container rebuilds; set this to a
# host bind-mount path to keep backups offsite-shippable.
# Empty disables the safety net (not recommended).
BACKUP_DIR=/app/data/backups
# Retention for the operator-runnable scripts/backup.sh. The in-process
# pre-migration rotator uses a separate 7-day default in code.
BACKUP_RETENTION_DAYS=7

# --- Docker (used by docker-compose.yml) ---
MYSQL_ROOT_PASSWORD=rootsecret
MYSQL_PASSWORD=chronicle  # must match DB_PASSWORD above
