		<table class="chronicle-table" style="max-width: 480px;">
			<tbody>
				<tr><td style="color: var(--chronicle-fg-muted); width: 40%;">Campaign name</td><td>The Reckoning</td><td style="width: 80px; text-align: right;"><button class="chronicle-button-ghost chronicle-button-ghost--sm">Edit</button></td></tr>
				<tr><td style="color: var(--chronicle-fg-muted);">System</td><td>Pathfinder 2e</td><td style="text-align: right;"><button class="chronicle-button-ghost chronicle-button-ghost--sm">Edit</button></td></tr>
				<tr><td style="color: var(--chronicle-fg-muted);">Members</td><td>12</td><td style="text-align: right;"><button class="chronicle-button-ghost chronicle-button-ghost--sm">Manage</button></td></tr>
			</tbody>
		</table>
	</section>
}

templ progressRing(value, hue int) {
	<div class="chronicle-progress-ring">
		<svg viewBox="0 0 64 64" width="64" height="64">
			<circle class="chronicle-progress-ring__track" cx="32" cy="32" r="28" fill="none" stroke-width="4"/>
			<circle class="chronicle-progress-ring__fill" cx="32" cy="32" r="28" fill="none" stroke-width="4" stroke-dasharray="175.93" stroke-dashoffset={ ringOffset(value) } stroke-linecap="round"/>
		</svg>
		<span class="chronicle-progress-ring__text">{ itoa(value) }%</span>
	</div>
}

func ringOffset(value int) string {
	// circumference 2*pi*r where r=28 ≈ 175.93
	// offset = circumference - (value/100 * circumference)
	off := 175.93 - (float64(value)/100.0)*175.93
	return ftoa(off)
}

func ftoa(f float64) string {
	// minimal float-to-string with 2 decimal places
	whole := int(f)
	frac := int((f - float64(whole)) * 100)
	if frac < 0 {
		frac = -frac
	}
	s := itoa(whole) + "."
	if frac < 10 {
		s += "0"
	}
	s += itoa(frac)
	return s
}

templ varietyOverlaysSection() {
	<section class="chronicle-section" id="variety-overlays">
